<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_sale_order_document">
        <t t-set="o" t-value="doc or (docs and docs[0])"/>
        <t t-if="o">
            <t t-if="o.state in ('sale', 'done')">
                <t t-call="landry_ika_odoo_module.report_bon_commande_document"/>
            </t>
            <t t-elif="o.proforma_signed == 'signed'">
                <t t-call="landry_ika_odoo_module.report_proforma_signature_document"/>
            </t>
            <t t-else="">
                <t t-call="landry_ika_odoo_module.report_proforma_document"/>
            </t>
        </t>
        <t t-else="">
            <div>No sale order record found for this report.</div>
        </t>
    </template>

    <record id="action_report_sale_order" model="ir.actions.report">
        <field name="name">Sale Order Report</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">landry_ika_odoo_module.report_sale_order_document</field>
        <field name="report_file">landry_ika_odoo_module.report_sale_order_document</field>
        <field name="print_report_name">'Sale Order - %s' % (object.name)</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
    </record>
</odoo>