<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="first_down_payment_invoice_1_content">
        <t t-set="o" t-value="doc"/>
        <t t-set="so" t-value="o.sale_order_id"/>

        <div class="page" style="font-family: Arial, Helvetica, sans-serif; color: #000000; font-size: 10pt; line-height: 1.5;">

            <!-- Date -->
            <div style="text-align: right; margin-bottom: 20px; margin-top: 25px; font-size: 10pt;">
OUAGADOUGOU, le <span t-field="o.invoice_date" t-options='{"format": "d MMMM Y"}'/>
            </div>

            <!-- Titre -->
            <div style="text-align: center; background-color: #615e5e; padding: 14px 12px; margin-bottom: 25px;">
                <h1 style="font-size: 16pt; font-weight: bold; text-transform: uppercase; margin: 0; letter-spacing: 1px; color: #000000;">
FACTURE D'ACOMPTE N° <span t-field="o.fac_number"/>
                </h1>
            </div>


            <!-- Infos Client -->
            <div style="padding: 15px 0px; margin-bottom: 15px;">
                <p style="margin: 0 0 8px 0; line-height: 1.6; font-size: 10pt;">
                    <span style="font-weight: bold;">DOIT :</span>
                    <span style="font-weight: bold;" t-field="o.partner_id.name"/>
                    <br/>
                    <span t-field="o.partner_id.street"/>
                    <t t-if="o.partner_id.street2">
,                        <span t-field="o.partner_id.street2"/>
                    </t>
                </p>

                <t t-if="o.partner_id.partner_rccm or o.partner_id.partner_ifu or o.partner_id.partner_division_fiscale or o.partner_id.partner_regime_fiscal">
                    <table style="width: 100%; margin: 8px 0; font-size: 9pt; border-collapse: collapse;" class="table table-borderless">
                        <tr>
                            <td t-if="o.partner_id.partner_rccm" style="padding: 2px 10px 2px 0;">
                                <strong>N° RCCM :</strong>
                                <span t-field="o.partner_id.partner_rccm"/>
                            </td>
                            <td t-if="o.partner_id.partner_ifu" style="padding: 2px 10px 2px 0;">
                                <strong>N° IFU :</strong>
                                <span t-field="o.partner_id.partner_ifu"/>
                            </td>
                            <td t-if="o.partner_id.partner_division_fiscale" style="padding: 2px 10px 2px 0;">
                                <strong>Division Fiscale :</strong>
                                <span t-field="o.partner_id.partner_division_fiscale"/>
                            </td>
                            <td t-if="o.partner_id.partner_regime_fiscal" style="padding: 2px 10px 2px 0;">
                                <strong>Régime fiscal :</strong>
                                <span t-field="o.partner_id.partner_regime_fiscal"/>
                            </td>
                        </tr>
                    </table>
                </t>

                <t t-if="o.partner_id.phone or o.partner_id.mobile or o.partner_id.email">
                    <div style="font-size: 9pt; margin-bottom: 8px;">
                        <t t-if="o.partner_id.phone or o.partner_id.mobile">
                            <strong>Tél :</strong>
                            <span t-field="o.partner_id.phone"/>
                            <t t-if="o.partner_id.phone and o.partner_id.mobile"> / </t>
                            <span t-field="o.partner_id.mobile"/>
                        </t>
                        <t t-if="o.partner_id.email">
                            <span style="margin-left: 15px;">
                                <strong>Email :</strong>
                                <span t-field="o.partner_id.email"/>
                            </span>
                        </t>
                    </div>
                </t>
            </div>

            <!-- Objet -->
            <div t-if="o.invoice_object" style="margin-bottom: 12px; font-size: 10pt;">
                <strong>OBJET :</strong>
                <span t-field="o.invoice_object"/>
            </div>

            <!-- Variables globales -->
            <t t-set="display_discount" t-value="(so and any(line.discount for line in so.order_line if not line.display_type)) or any(line.discount for line in o.invoice_line_ids if not line.display_type)"/>
            <t t-set="dp_percentage" t-value="round((o.amount_untaxed / so.amount_untaxed) * 100, 2) if so and so.amount_untaxed else 0"/>

            <!-- Tableau des lignes du bon de commande avec MONTANT TOTAL TTC -->
            <t t-if="so">
                <t t-set="lines_to_report" t-value="[(idx, line) for idx, line in enumerate(so.order_line) if not line.is_downpayment]"/>
                <table class="table table-bordered" style="width: 100%; border-collapse: collapse;font-size: 9pt;">
                    <thead>
                        <tr style="background-color: #615e5e; color: #000000; font-weight: bold; font-size: 9pt;">
                            <th style="padding: 8px 10px; text-align: left; ">Description</th>
                            <th style="padding: 8px 10px; text-align: right; ">Quantité</th>
                            <th style="padding: 8px 10px; text-align: left; ">Unité</th>
                            <th style="padding: 8px 10px; text-align: right; ">Prix Unitaire</th>
                            <th t-if="display_discount" style="padding: 8px 10px; text-align: right; ">Remise (%)</th>
                            <th style="padding: 8px 10px; text-align: right; ">Montant</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="current_subtotal" t-value="0"/>
                        <t t-set="current_section" t-value="None"/>
                        <t t-foreach="lines_to_report" t-as="line_info">
                            <t t-set="line_index" t-value="line_info[0]"/>
                            <t t-set="line" t-value="line_info[1]"/>
                            <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"/>
                            <t t-set="line_last" t-value="line_index == (len(lines_to_report) - 1)"/>

                            <tr t-att-class="'fw-bold' if line.display_type == 'line_section' else 'fst-italic' if line.display_type == 'line_note' else ''">
                                <t t-if="not line.display_type and not line.is_downpayment">
                                    <td style="padding: 6px 10px; ">
                                        <span t-field="line.name"/>
                                    </td>
                                    <td style="padding: 6px 10px; text-align: right; white-space: nowrap; ">
                                        <span t-field="line.product_uom_qty"/>
                                    </td>
                                    <td style="padding: 6px 10px; ">
                                        <span t-field="line.product_uom"/>
                                    </td>
                                    <td style="padding: 6px 10px; text-align: right; ">
                                        <span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                    <td t-if="display_discount" style="padding: 6px 10px; text-align: right; ">
                                        <t t-if="line.discount">
                                            <span t-field="line.discount"/>
%
                                        </t>
                                    </td>
                                    <td style="padding: 6px 10px; text-align: right; font-weight: bold; ">
                                        <span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                </t>
                                <t t-elif="line.display_type == 'line_section'">
                                    <td colspan="99" style="padding: 6px 10px; font-weight: bold; ">
                                        <span t-field="line.name"/>
                                    </td>
                                    <t t-set="current_section" t-value="line"/>
                                    <t t-set="current_subtotal" t-value="0"/>
                                </t>
                                <t t-elif="line.display_type == 'line_note'">
                                    <td colspan="99" style="padding: 6px 10px; color: #666; ">
                                        <span t-field="line.name"/>
                                    </td>
                                </t>
                            </tr>

                            <t t-if="current_section and (line_last or lines_to_report[line_index+1][1].display_type == 'line_section') and not line.is_downpayment">
                                <tr style="background-color: #f5f5f5;">
                                    <td colspan="99" style="padding: 6px 10px; text-align: right; font-weight: bold; border: 1px solid #ddd;">
Sous-total : <span t-out="current_subtotal" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                </tr>
                                <t t-set="current_section" t-value="None"/>
                            </t>
                        </t>
                        <tr style="">
                            <td colspan="5" t-att-colspan="5 if display_discount else 4" style="padding: 8px 10px; text-align: right; font-weight: 900; text-transform: uppercase;  color: #000000;">
MONTANT TOTAL TTC
                            </td>
                            <td style="padding: 8px 10px; text-align: right; font-weight: 900; font-size: 10pt;color: #000000;">
                                <span t-field="so.amount_total" t-options='{"widget": "monetary", "display_currency": so.currency_id}'/>
                            </td>
                        </tr>
                        <tr style="font-size: 12pt; font-weight: bold; text-transform: uppercase; color: #000000; padding: 8px 10px; margin-bottom: 0;">
                            <td colspan="6" t-att-colspan="6 if display_discount else 5">
                                <strong> ACOMPTES </strong>
                            </td>
                        </tr>

                        <tr>

                            <td style="padding: 8px 10px;">
                                <strong>Acompte n°1 à payer (<span t-esc="dp_percentage"/>
%)</strong>
                            </td>
                            <td style="padding: 6px 10px; text-align: right; font-weight: bold;">
                            </td>
                            <td style="padding: 6px 10px; text-align: right; font-weight: bold;">
                            </td>
                            <td style="padding: 6px 10px; text-align: right; font-weight: bold;">
                            </td>
                            <td style="padding: 8px 10px; text-align: right; font-weight: bold;">
                                <span t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </t>

            <!-- Lignes de facture sans SO -->
            <t t-if="not so">
                <table class="table table-bordered" style="width: 100%; border-collapse: collapse;font-size: 9pt;">
                    <thead>
                        <tr style="background-color: #615e5e; color: #000000; font-weight: bold; font-size: 9pt;">
                            <th style="padding: 8px 10px; text-align: left; ">Description</th>
                            <th style="padding: 8px 10px; text-align: right; ">Quantité</th>
                            <th style="padding: 8px 10px; text-align: left; ">Unité</th>
                            <th style="padding: 8px 10px; text-align: right; ">Prix Unitaire</th>
                            <th t-if="display_discount" style="padding: 8px 10px; text-align: right; ">Remise (%)</th>
                            <th style="padding: 8px 10px; text-align: right; ">Montant</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="o.invoice_line_ids" t-as="line">
                            <t t-if="not line.display_type">
                                <tr>
                                    <td style="padding: 6px 10px; ">
                                        <span t-field="line.name"/>
                                    </td>
                                    <td style="padding: 6px 10px; text-align: right;">
                                        <span t-field="line.quantity"/>
                                    </td>
                                    <td style="padding: 6px 10px;">
                                        <span t-field="line.product_uom_id" t-if="line.product_uom_id"/>
                                    </td>
                                    <td style="padding: 6px 10px; text-align: right;">
                                        <span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                    <td t-if="display_discount" style="padding: 6px 10px; text-align: right;">
                                        <t t-if="line.discount">
                                            <span t-field="line.discount"/>
%</t>
                                    </td>
                                    <td style="padding: 6px 10px; text-align: right; font-weight: bold;">
                                        <span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                </tr>
                            </t>
                        </t>
                    </tbody>
                </table>
            </t>


            <!-- Acompte à payer et reste -->
            <div style="margin-top: 15px;">
                <div style="width: 50%; margin-left: auto; overflow: hidden;">
                    <table style="width: 100%; font-size: 9pt; border:none" class="table table-borderless">
                        <tr style="border:none; ">
                            <td style="padding: 10px; font-weight: 900; text-transform: uppercase; border:none;">Acompte à payer</td>
                            <td style="padding: 10px; text-align: right; font-weight: 900; font-size: 10pt; border:none;">
                                <span t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </td>
                        </tr>
                        <t t-if="so">
                            <t t-set="reste_a_payer" t-value="so.amount_total - o.amount_total"/>
                            <tr style="border:none; ">
                                <td style="padding: 10px; font-weight: 900; text-transform: uppercase; border:none;">RESTE À PAYER</td>
                                <td style="padding: 10px; text-align: right; font-weight: 900; font-size: 10pt; color: #000000; border:none;">
                                    <span t-out="reste_a_payer" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                </td>
                            </tr>
                        </t>
                    </table>
                </div>
            </div>

            <!-- Communication de paiement -->
            <div style="font-size: 9pt; margin-top: 15px; padding-top: 10px;">
                <span>Communication de paiement :</span>
                <strong t-field="o.name"/>
                <br/>
                <span>Sur ce compte :</span>
                <strong t-field="o.partner_bank_id.acc_number"/>
 -
                <strong t-field="o.partner_bank_id.bank_id.name"/>
            </div>

            <!-- Montant en lettres -->
            <div style="margin-top: 10px; font-size: 9pt; font-style: italic;">
Arrêtée la présente facture d'acompte à la somme de :
                <strong style="text-transform: uppercase; font-style: normal;" t-esc="o.currency_id.amount_to_text(o.amount_total)"/>
(                <span t-esc="'{:,.0f}'.format(o.amount_total).replace(',', ' ')"/>
) FRANCS CFA
            </div>

            <!-- Conditions de paiement -->
            <div t-if="o.invoice_payment_term_id" style="font-size: 9pt; margin-top: 20px; border-radius: 4px;">
                <strong>Conditions de paiement :</strong>
                <span t-field="o.invoice_payment_term_id.name"/>
            </div>

            <!-- Remarques -->
            <div t-if="o.narration" style="font-size: 9pt; margin-top: 15px; padding-top: 10px;">
                <strong>Remarques :</strong>
                <br/>
                <span t-field="o.narration"/>
            </div>

        </div>
    </template>

    <template id="first_down_payment_invoice_1_template">
        <t t-call="landry_ika_odoo_module.external_layout_ika">
            <t t-set="o" t-value="doc"/>
            <t t-call="landry_ika_odoo_module.first_down_payment_invoice_1_content"/>
        </t>
    </template>

</odoo>
