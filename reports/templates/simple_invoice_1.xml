<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="simple_invoice_1_content">
<t t-set="o" t-value="doc"/>

<div class="page" style="font-family: Arial, Helvetica, sans-serif; color: #000000; font-size: 10pt; line-height: 1.5;">

<!-- Date -->
<div style="text-align: right; margin-bottom: 20px; margin-top: 25px; font-size: 10pt;">
OUAGADOUGOU, le <span t-field="o.invoice_date" t-options='{"format": "d MMMM Y"}'/>
</div>

<!-- Titre -->
<div style="text-align: center; background-color: #615e5e; padding: 14px 12px; margin-bottom: 25px;">
<h1 style="font-size: 16pt; font-weight: bold; text-transform: uppercase; margin: 0; letter-spacing: 1px; color: #000000;">
FACTURE standard N° <span t-field="o.name"/>
</h1>
</div>

<!-- Infos Client -->
<div style="padding: 15px 0px; margin-bottom: 15px;">
<p style="margin: 0 0 8px 0; line-height: 1.6; font-size: 10pt;">
<span style="font-weight: bold;">DOIT :</span>
<span style="font-weight: bold;" t-field="o.partner_id.name"/><br/>
<span t-field="o.partner_id.street"/>
<t t-if="o.partner_id.street2">
, <span t-field="o.partner_id.street2"/>
</t>
</p>

<t t-if="o.partner_id.partner_rccm or o.partner_id.partner_ifu or o.partner_id.partner_division_fiscale or o.partner_id.partner_regime_fiscal">
<table style="width: 100%; margin: 8px 0; font-size: 9pt; border-collapse: collapse;" class="table table-borderless">
<tr>
<td t-if="o.partner_id.partner_rccm" style="padding: 2px 10px 2px 0;">
<strong>N° RCCM :</strong> <span t-field="o.partner_id.partner_rccm"/>
</td>
<td t-if="o.partner_id.partner_ifu" style="padding: 2px 10px 2px 0;">
<strong>N° IFU :</strong> <span t-field="o.partner_id.partner_ifu"/>
</td>
<td t-if="o.partner_id.partner_division_fiscale" style="padding: 2px 10px 2px 0;">
<strong>Division Fiscale :</strong> <span t-field="o.partner_id.partner_division_fiscale"/>
</td>
<td t-if="o.partner_id.partner_regime_fiscal" style="padding: 2px 10px 2px 0;">
<strong>Régime fiscal :</strong> <span t-field="o.partner_id.partner_regime_fiscal"/>
</td>
</tr>
</table>
</t>

<t t-if="o.partner_id.phone or o.partner_id.mobile or o.partner_id.email">
<div style="font-size: 9pt; margin-bottom: 8px;">
<t t-if="o.partner_id.phone or o.partner_id.mobile">
<strong>Tél :</strong>
<span t-field="o.partner_id.phone"/>
<t t-if="o.partner_id.phone and o.partner_id.mobile"> / </t>
<span t-field="o.partner_id.mobile"/>
</t>
<t t-if="o.partner_id.email">
<span style="margin-left: 15px;">
<strong>Email :</strong> <span t-field="o.partner_id.email"/>
</span>
</t>
</div>
</t>
</div>

<!-- Objet -->
<div t-if="o.invoice_object" style="margin-bottom: 12px; font-size: 10pt;">
<strong>OBJET :</strong> <span t-field="o.invoice_object"/>
</div>

<!-- Commercial & Echéance -->
<div style="display: table; width: 100%; margin-bottom: 10px; font-size: 9pt;">
<div style="display: table-row;">
<div style="display: table-cell; width: 50%; padding: 10px; text-align: right;">
<strong>Commercial(e) :</strong> <span t-field="o.invoice_user_id.name"/>
</div>
<div style="display: table-cell; width: 50%; text-align: left; padding: 10px;">
<strong>Echéance :</strong> <span t-field="o.invoice_date_due"/>
</div>
</div>
</div>

<!-- Tableau des articles -->
<t t-if="o.sale_order_id">
<t t-set="so" t-value="o.sale_order_id"/>
<t t-set="display_discount" t-value="any(line.discount for line in so.order_line if not line.display_type)"/>

<table class="table table-bordered" style="width: 100%; border-collapse: collapse; margin-bottom: 25px; font-size: 9pt;">
<thead>
<tr style="background-color: #615e5e; color: #000000; font-weight: bold; font-size: 9pt;">
<th style="padding: 8px 10px; text-align: left; border: 1px solid #000000;">Description</th>
<th style="padding: 8px 10px; text-align: right; border: 1px solid #000000;">Quantité</th>
<th style="padding: 8px 10px; text-align: left; border: 1px solid #000000;">Unité</th>
<th style="padding: 8px 10px; text-align: right; border: 1px solid #000000;">Prix Unitaire</th>
<th t-if="display_discount" style="padding: 8px 10px; text-align: right; border: 1px solid #000000;">Remise (%)</th>
<th style="padding: 8px 10px; text-align: right; border: 1px solid #000000;">Montant</th>
</tr>
</thead>
<tbody>
<t t-foreach="so.order_line" t-as="line">
<t t-if="not line.display_type and not line.is_downpayment">
<tr>
<td style="padding: 6px 10px; border: 1px solid #000000;">
<span t-field="line.name"/>
</td>
<td style="padding: 6px 10px; text-align: right; white-space: nowrap; border: 1px solid #000000;">
<span t-field="line.product_uom_qty"/>
</td>
<td style="padding: 6px 10px; border: 1px solid #000000;">
<span t-field="line.product_uom"/>
</td>
<td style="padding: 6px 10px; text-align: right; border: 1px solid #000000;">
<span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
</td>
<td t-if="display_discount" style="padding: 6px 10px; text-align: right; border: 1px solid #000000;">
<t t-if="line.discount">
<span t-field="line.discount"/>%
</t>
</td>
<td style="padding: 6px 10px; text-align: right; font-weight: bold; border: 1px solid #000000;">
<span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
</td>
</tr>
</t>
</t>
</tbody>
</table>
</t>
<t t-else="">
<t t-set="display_discount" t-value="any(line.discount for line in o.invoice_line_ids if not line.display_type)"/>

<table class="table table-bordered" style="width: 100%; border-collapse: collapse; margin-bottom: 25px; font-size: 9pt;">
<thead>
<tr style="background-color: #615e5e; color: #000000; font-weight: bold; font-size: 9pt;">
<th style="padding: 8px 10px; text-align: left; border: 1px solid #000000;">Description</th>
<th style="padding: 8px 10px; text-align: right; border: 1px solid #000000;">Quantité</th>
<th style="padding: 8px 10px; text-align: left; border: 1px solid #000000;">Unité</th>
<th style="padding: 8px 10px; text-align: right; border: 1px solid #000000;">Prix Unitaire</th>
<th t-if="display_discount" style="padding: 8px 10px; text-align: right; border: 1px solid #000000;">Remise (%)</th>
<th style="padding: 8px 10px; text-align: right; border: 1px solid #000000;">Montant</th>
</tr>
</thead>
<tbody>
<t t-foreach="o.invoice_line_ids" t-as="line">
<t t-if="not line.display_type">
<tr>
<td style="padding: 6px 10px; border: 1px solid #000000;">
<span t-field="line.name"/>
</td>
<td style="padding: 6px 10px; text-align: right; white-space: nowrap; border: 1px solid #000000;">
<span t-field="line.quantity"/>
</td>
<td style="padding: 6px 10px; border: 1px solid #000000;">
<span t-field="line.product_uom_id" t-if="line.product_uom_id"/>
</td>
<td style="padding: 6px 10px; text-align: right; border: 1px solid #000000;">
<span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
</td>
<td t-if="display_discount" style="padding: 6px 10px; text-align: right; border: 1px solid #000000;">
<t t-if="line.discount">
<span t-field="line.discount"/>%
</t>
</td>
<td style="padding: 6px 10px; text-align: right; font-weight: bold; border: 1px solid #000000;">
<span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
</td>
</tr>
</t>
</t>
</tbody>
</table>
</t>

<!-- Totaux -->
<div style="width: 100%; margin-top: 10px;">
<div style="width: 40%; margin-left: auto; overflow: hidden;">
<table style="width: 100%; font-size: 9pt; border-collapse: collapse;" class="table table-borderless">
<tr>
<td style="padding: 6px 10px; font-weight: bold;">MONTANT HT</td>
<td style="padding: 6px 10px; text-align: right;">
<span t-field="o.amount_untaxed" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
</td>
</tr>
<tr>
<td style="padding: 6px 10px; font-weight: bold;">TVA 18%</td>
<td style="padding: 6px 10px; text-align: right;">
<span t-field="o.amount_tax" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
</td>
</tr>
<tr style="">
<td style="padding: 8px 10px; font-weight: 900; text-transform: uppercase;">MONTANT NET A PAYER</td>
<td style="padding: 8px 10px; text-align: right; font-weight: 900; font-size: 10pt;">
<span t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
</td>
</tr>
</table>
</div>
</div>

<!-- Communication de paiement -->
<div style="font-size: 9pt; margin-top: 15px; padding-top: 10px;">
<span>Communication de paiement :</span> <strong t-field="o.name"/>
<br/><span>Sur ce compte :</span>
<strong t-field="o.partner_bank_id.acc_number"/> -
<strong t-field="o.partner_bank_id.bank_id.name"/>
</div>

<!-- Montant en lettres -->
<div style="margin-top: 10px; font-size: 9pt; font-style: italic;">
Arrêtée la présente facture à la somme de :
<strong style="text-transform: uppercase; font-style: normal;" t-esc="o.currency_id.amount_to_text(o.amount_total)"/>
(<span t-esc="'{:,.0f}'.format(o.amount_total).replace(',', ' ')"/>) FRANCS CFA
</div>

<!-- Conditions de paiement -->
<div t-if="o.invoice_payment_term_id" style="font-size: 9pt; margin-top: 20px; border-radius: 4px;">
<strong>Conditions de paiement :</strong>
<span t-field="o.invoice_payment_term_id.name"/>
</div>

<!-- Remarques -->
<div t-if="o.narration" style="font-size: 9pt; margin-top: 15px; padding-top: 10px;">
<strong>Remarques :</strong><br/>
<span t-field="o.narration"/>
</div>

</div>
</template>

<template id="simple_invoice_1_template">
<t t-call="landry_ika_odoo_module.external_layout_ika">
<t t-set="o" t-value="doc"/>
<t t-call="landry_ika_odoo_module.simple_invoice_1_content"/>
</t>
</template>

</odoo>
