<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="invoice_form_custom" model="ir.ui.view">
    <field name="name">account.move.form.custom.invoice.object</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">
        <xpath expr="//group[@id='header_right_group']" position="inside">
            <field name="invoice_type_display" readonly="1"
                invisible="move_type != 'out_invoice'"
                string="Type de facture"
                style="font-weight: 600; color: #856404; background-color: #fff3cd; border: 1px solid #ffc107; border-radius: 4px; padding: 4px 10px;"/>
        </xpath>
        <xpath expr="//field[@name='invoice_date']" position="after">
            <field name="invoice_object" placeholder="Objet de la facture"/>
        </xpath>
    </field>
</record>

</odoo>
