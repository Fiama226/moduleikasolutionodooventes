<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="invoice_type_wizard_form" model="ir.ui.view">
    <field name="name">Invoice Type Selection Dialog</field>
    <field name="model">account.move.invoice.type.wizard</field>
    <field name="arch" type="xml">
        <form>
            <div class="alert alert-info" role="alert" style="margin-bottom: 15px;">
                <field name="message" nolabel="1" readonly="1"/>
            </div>

            <group>
                <field name="move_id" invisible="1"/>
                <field name="sale_order_id" invisible="1"/>

                <div>
                    <label for="invoice_type" string="Type de Facture" class="fw-bold"/>
                    <br/>
                    <field name="invoice_type" widget="radio" nolabel="1"/>
                </div>
            </group>

            <footer>
                <button name="action_confirm" type="object"
                        string="Confirmer" class="btn-primary"/>
                <button special="cancel" string="Annuler"
                        class="btn-secondary"/>
            </footer>
        </form>
    </field>
</record>

<record id="action_invoice_type_wizard" model="ir.actions.act_window">
    <field name="name">Selection du Type de Facture</field>
    <field name="res_model">account.move.invoice.type.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
</record>

</odoo>
