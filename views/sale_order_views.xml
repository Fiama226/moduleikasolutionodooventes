<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_order_view_form_ika" model="ir.ui.view">
        <field name="name">sale.order.view.form.ika</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <field name="name" position="after">
<div class="d-flex align-items-baseline" 
     invisible="state not in ('sale', 'done') or proforma_number == False">
    <span style="font-weight: bold; font-size: 12px; margin-right: 15px; width: 20%;">
        De la Proforma n°:
    </span>
    <field name="proforma_number"
           readonly="1"
           nolabel="1"
           style="font-weight: bold; font-size: 12px; "/>
</div>

                <label for="proforma_object" string="Objet :"/>
      <field name="proforma_object"
      placeholder="ex: Fourniture de matériel informatique"
      nolabel="1"
      required="1"
      style="max-width: 300px;"/>
                       
                <field name="proforma_signed"
                       string="Proforma signée"
                       widget="radio"
                       options="{'horizontal': true}"
                       style="margin-left: 120px;"
                       invisible="state in ('sale', 'done')"/>
                       
            </field>



            <xpath expr="//header" position="inside">
                <button name="action_print_sale_document"
                        type="object"
                        string="Imprimer document"
                        class="oe_highlight"
                        invisible="state not in ('draft', 'sent', 'sale', 'done')"/>
            </xpath>
    </field>
    </record>

    </odoo>
